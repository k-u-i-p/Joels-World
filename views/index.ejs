<!doctype html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport"
    content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <link rel="icon" type="image/png" href="/favicon.png" />
  <link rel="stylesheet" href="/src/style.css" />
  <title>
    <%= isAdmin ? "Joels World Admin" : "Joels World" %>
  </title>
</head>

<body>

  <!-- Top Center UI Overlay -->
  <div id="top-center-ui" class="overlay">
    <div id="top-center-ui-wrapper">
      <div id="top-center-ui-header">
        <div id="avatars-container"></div>
        <div id="top-center-ui-header-right">
          <div id="map-name-display"></div>
          <div id="chat-container">
            <input type="text" id="chat-input" class="glass-input" placeholder="Click to chat..." autocomplete="off"
              maxlength="80" />
          </div>
        </div>
      </div>

      <div id="server-chat-stack"></div>

      <div id="action-dialog" class="dialog-content" style="display: none;">
        <h2 id="action-dialog-text"></h2>
        <div class="action-dialog-buttons">
          <button id="action-dialog-yes" class="btn btn-success btn-action">Yes</button>
          <button id="action-dialog-no" class="btn btn-danger btn-action">No</button>
        </div>
      </div>
    </div>
  </div>

  <!-- Loading Dialog Overlay -->
  <div id="loading-dialog" class="overlay">
    <div class="dialog-content">
      <img src="media/logo_128_128.png" alt="Joel's World Logo"
        style="display: block; margin: 0 auto 15px auto; width: 128px; height: 128px;" />
      <h2 style="margin-bottom: 0;">Loading...</h2>
    </div>
  </div>

  <!-- Naming Dialog Overlay -->
  <div id="name-dialog" class="overlay" style="display: none;">
    <div class="dialog-content">
      <img src="media/logo_128_128.png" alt="Joel's World Logo"
        style="display: block; margin: 0 auto 15px auto; width: 128px; height: 128px;" />
      <h2>Welcome to Joel's World</h2>
      <input type="text" id="player-name-input" class="glass-input" placeholder="Enter your name..." maxlength="15"
        autocomplete="off" />
      <br>
      <button id="start-game-btn" class="btn btn-success">Start Game</button>
    </div>
  </div>

  <!-- Help Dialog Overlay -->
  <div id="help-dialog" class="overlay" style="display: none;">
    <div style="position: relative; max-width: 450px; width: 90%;">
      <button id="close-help-btn" class="dialog-close-btn">&times;</button>
      <div class="dialog-content glass-panel" style="text-align: left; width: 100%;">
        <h2 style="text-align: center; font-size: 24px; margin-bottom: 25px; color: #fff;">Help</h2>

        <div class="help-section">
        <h3><span class="icon">🎮</span> Controls</h3>
        <ul class="help-list">
          <li><strong>Keyboard:</strong> Arrow keys to move and turn.</li>
          <li><strong>Mobile:</strong> Use the virtual joysticks to move and turn.</li>
          <li><strong>Interact:</strong> Figure out how to escape school!</li>
        </ul>
      </div>

      <div class="help-section">
        <h3><span class="icon">💬</span> Chat</h3>
        <p style="margin: 0 0 10px 0; font-size: 14px; color: #cbd5e1;">Press Enter to type a message to other players.
        </p>
      </div>
    </div>
  </div>
</div>

  <!-- Emotes Dialog Overlay -->
  <div id="emotes-dialog" class="overlay" style="display: none;">
    <div style="position: relative; max-width: 350px; width: 80%;">
      <button id="close-emotes-btn" class="dialog-close-btn">&times;</button>
      <div class="dialog-content glass-panel" style="text-align: left; width: 100%; padding: 15px; max-height: calc(100dvh - env(safe-area-inset-top) - env(safe-area-inset-bottom) - 80px); overflow-y: auto;">
        <h2 style="text-align: center; font-size: 20px; margin-bottom: 15px; margin-top: 0; color: #fff;">Emotes</h2>
        <% 
          const emoteEmojis = {
          dance: '🕺', fart: '💨', dead: '💀', cry: '😭', rugby: '🏉', 
          sit: '🪑', jump: '🦘', eat: '🍔', lunch: '🥪'
        };
      %>
      <div id="emotes-list" style="display: flex; flex-direction: column; gap: 8px;">
        <% validEmotes.forEach(emote => { %>
          <div class="emote-row" data-emote="<%= emote %>">
            <span class="emote-row-icon"><%= emoteEmojis[emote] || '💬' %></span>
            <span class="emote-row-name"><%= emote.charAt(0).toUpperCase() + emote.slice(1) %></span>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
</div>

  <!-- Minimap Dialog Overlay -->
  <div id="minimap-dialog" class="overlay" style="display: none;">
    <div style="position: relative;">
      <button id="close-minimap-btn" class="dialog-close-btn">&times;</button>
      <div id="minimap-wrapper">
        <img id="minimap-image" src="" alt="Minimap" />
        <div id="minimap-player-dot"></div>
      </div>
    </div>
  </div>

  <% if (isAdmin) { %>
    <script>window.isAdmin = true;</script>
    <div id="admin-fps"
      style="position: absolute; top: 10px; right: 10px; color: yellow; background: rgba(0,0,0,0.5); padding: 5px; font-family: monospace; z-index: 10000; border-radius: 4px;">
      FPS: --</div>
    <div id="admin-panel" style="display: none;">
      <div id="admin-panel-handle" class="admin-handle">
        Admin Panel
      </div>
      <div style="margin-bottom: 10px; text-align: center;">
        <select id="admin-map-select" class="admin-select">
          <option value="">Select Map...</option>
        </select>
        <button id="btn-create-obj-rect" class="admin-full-btn" style="background-color: #e67e22;">+ Collision
          Box</button>
        <button id="btn-create-obj-circle" class="admin-full-btn" style="background-color: #f1c40f;">+ Collision
          Circle</button>
        <button id="btn-create-npc" class="admin-full-btn" style="background-color: #9b59b6;">+ NPC</button>
      </div>
      <div id="admin-last-clicked"
        style="font-size: 12px; font-family: monospace; color: #bdc3c7; text-align: center; margin-bottom: 5px;">
        Last Click: x: -, y: -
      </div>

      <div id="edit-obj-section" style="display: none;">
        <h3>Edit Object</h3>
        <div id="obj-id-display"
          style="font-size: 12px; font-family: monospace; color: #bdc3c7; text-align: center; margin-bottom: 8px; word-wrap: break-word;">
          ID: -</div>
        <div style="text-align:center; margin-bottom:10px;">
          <input type="text" id="obj-name-input" class="admin-input" placeholder="Object Name (Optional)" />
        </div>
        <div class="admin-control-row">
          <span>Rotate:</span>
          <button id="btn-obj-rot-left" class="admin-btn">↺</button>
          <button id="btn-obj-rot-right" class="admin-btn">↻</button>
        </div>
        <div class="admin-control-row">
          <span>Width:</span>
          <button id="btn-obj-width-dec" class="admin-btn">-</button>
          <button id="btn-obj-width-inc" class="admin-btn">+</button>
        </div>
        <div class="admin-control-row">
          <span>Length:</span>
          <button id="btn-obj-length-dec" class="admin-btn">-</button>
          <button id="btn-obj-length-inc" class="admin-btn">+</button>
        </div>
        <div class="admin-control-row" style="margin-top: 5px;">
          <span>Clip:</span>
          <input type="number" id="input-obj-clip"
            style="width: 60px; padding: 3px; font-size: 12px; border-radius: 4px; border: 1px solid #7f8c8d; background: rgba(255,255,255,0.1); color: white; text-align: center;" />
        </div>
        <button id="btn-delete-obj" class="admin-full-btn" style="background-color:#e74c3c; margin-top:10px;">Delete
          Object</button>
      </div>
      <div id="edit-npc-section" style="display: none; margin-top: 15px;">
        <h3>Edit NPC</h3>
        <div style="text-align:center; margin-bottom:5px;">
          <input type="text" id="npc-name-input" class="admin-input" placeholder="NPC Name" />
        </div>
        <details open>
          <summary style="cursor: pointer; font-size: 13px; font-weight: bold; margin-bottom: 5px; color: #3498db;">
            Layout & Constraints</summary>
          <div style="padding-left: 5px; margin-bottom: 10px;">
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Rotate:</span>
              <button id="btn-npc-rot-left" class="admin-btn">↺</button>
              <button id="btn-npc-rot-right" class="admin-btn">↻</button>
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Width:</span>
              <button id="btn-npc-width-dec" class="admin-btn">-</button>
              <button id="btn-npc-width-inc" class="admin-btn">+</button>
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Height:</span>
              <button id="btn-npc-height-dec" class="admin-btn">-</button>
              <button id="btn-npc-height-inc" class="admin-btn">+</button>
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Radius:</span>
              <input type="number" id="npc-radius-input"
                style="width: 60px; padding: 3px; font-size: 12px; border-radius: 4px; border: 1px solid #7f8c8d; background: rgba(255,255,255,0.1); color: white; text-align: center;" />
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Roam Radius:</span>
              <input type="number" id="npc-roam-radius-input" title="Set to 0 to disable roaming"
                style="width: 60px; padding: 3px; font-size: 12px; border-radius: 4px; border: 1px solid #7f8c8d; background: rgba(255,255,255,0.1); color: white; text-align: center;" />
            </div>
          </div>
        </details>

        <details>
          <summary style="cursor: pointer; font-size: 13px; font-weight: bold; margin-bottom: 5px; color: #2ecc71;">
            Appearance</summary>
          <div style="padding-left: 5px; margin-bottom: 10px;">
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Gender: </span>
              <select id="npc-gender-select"
                style="width: 80px; padding: 2px; font-size: 12px; border-radius: 4px; background: rgba(255,255,255,0.1); color: white; border: 1px solid #7f8c8d;">
                <option value="male" style="color: black;">Male</option>
                <option value="female" style="color: black;">Female</option>
              </select>
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Shirt: </span><input type="color" id="npc-shirt-col" class="admin-color-picker" />
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Pants: </span><input type="color" id="npc-pants-col" class="admin-color-picker" />
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Arms: </span><input type="color" id="npc-arm-col" class="admin-color-picker" />
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Hair Col: </span><input type="color" id="npc-hair-col" class="admin-color-picker" />
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Hair Style: </span>
              <select id="npc-hair-style"
                style="width: 80px; padding: 2px; font-size: 12px; border-radius: 4px; background: rgba(255,255,255,0.1); color: white; border: 1px solid #7f8c8d;">
                <% validHairStyles.forEach(style => { %>
                  <option value="<%= style %>" style="color: black;"><%= style.charAt(0).toUpperCase() + style.slice(1) %></option>
                <% }) %>
              </select>
            </div>
            <div class="admin-control-row" style="margin-bottom:5px;">
              <span>Emote: </span>
              <select id="npc-default-emote"
                style="width: 80px; padding: 2px; font-size: 12px; border-radius: 4px; background: rgba(255,255,255,0.1); color: white; border: 1px solid #7f8c8d;">
                <option value="" style="color: black;">None</option>
                <% validEmotes.forEach(emote => { %>
                  <option value="<%= emote %>" style="color: black;"><%= emote.charAt(0).toUpperCase() + emote.slice(1) %></option>
                <% }) %>
              </select>
            </div>
          </div>
        </details>

        <button id="btn-delete-npc" class="admin-full-btn" style="background-color:#e74c3c; margin-top: 10px;">Delete
          NPC</button>
      </div>

      <div id="admin-events-section" style="display: none; margin-top: 15px;">
        <h3>Event Triggers</h3>
        <details open>
          <summary style="cursor: pointer; font-size: 13px; font-weight: bold; margin-bottom: 5px; color: #f1c40f;">On Enter</summary>
          <div id="events-on-enter-container" style="padding-left: 5px; margin-bottom: 10px;">
            <!-- Dynamic Actions -->
          </div>
          <button id="btn-add-on-enter" class="admin-full-btn" style="background-color:#2ecc71; margin-bottom: 5px; font-size:11px; padding:4px;">+ Add Action</button>
        </details>
        <details>
          <summary style="cursor: pointer; font-size: 13px; font-weight: bold; margin-bottom: 5px; color: #e67e22;">On Exit</summary>
          <div id="events-on-exit-container" style="padding-left: 5px; margin-bottom: 10px;">
            <!-- Dynamic Actions -->
          </div>
          <button id="btn-add-on-exit" class="admin-full-btn" style="background-color:#2ecc71; margin-bottom: 5px; font-size:11px; padding:4px;">+ Add Action</button>
        </details>
        
        <button id="btn-save-events" class="admin-full-btn" style="background-color:#3498db; margin-top: 10px;">Save Events</button>
      </div>
    </div>
    <% } else { %>
      <div id="ui-buttons-container">
        <button id="map-button" title="Map (M)"></button>
        <button id="emotes-button" title="Emotes">☺️</button>
        <button id="help-button">?</button>
      </div>
    <% } %>

        <div id="joystick-move-container">
          <div id="joystick-move-knob"></div>
        </div>
        <canvas id="gameCanvas"></canvas>
        <% if (isAdmin) { %>
          <script>
            window.isAdmin = true;
          </script>
          <template id="admin-emote-template">
            <select style="width: 100%; padding: 2px; font-size: 12px; background: rgba(255,255,255,0.1); color: white;">
              <option value="" style="color: black;">Select...</option>
              <% validEmotes.forEach(emote => { %>
                <option value="<%= emote %>" style="color: black;"><%= emote.charAt(0).toUpperCase() + emote.slice(1) %></option>
              <% }) %>
            </select>
          </template>
          <script type="module" src="/src/admin.js"></script>
          <% } %>
            <script type="module" src="/src/main.js"></script>
</body>

</html>